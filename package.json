{
  "name": "agent-manager",
  "version": "1.0.0",
  "description": "A project management tool for AI agents.",
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run ui:dev\"",
    "server:dev": "tsx watch --tsconfig ./backend/tsconfig.json backend/src/index.ts --ui --api",
    "server:build": "tsc -p ./backend/tsconfig.json",
    "server:start": "node ./backend/dist/index.js --ui --api",
    "ui:dev": "cd frontend && npm run dev",
    "ui:build": "cd frontend && npm run build",
    "build": "npm run server:build && npm run ui:build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx --tsconfig ./backend/tsconfig.json ./backend/src/infra/db/seed-auth.ts"
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.8",
    "@mdi/font": "^7.4.47",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "connect-history-api-fallback": "^2.0.0",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "node-cache": "^5.1.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/connect-history-api-fallback": "^1.5.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/passport": "^1.0.17",
    "concurrently": "^9.2.1"
  }
}
