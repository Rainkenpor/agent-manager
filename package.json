{
  "name": "agent-manager",
  "version": "1.0.0",
  "description": "A project management tool for AI agents.",
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run ui\"",
    "start:prod": "npm run server:build && npm run ui:build && npm run server:start",
    "server": "tsx watch --tsconfig ./backend/tsconfig.json backend/src/index.ts --ui --api",
    "server:build": "tsc -p ./backend/tsconfig.json && tsc-alias -p ./backend/tsconfig.json",
    "server:start": "node ./backend/dist/src/index.js --ui --api",
    "ui": "cd frontend && npm run dev",
    "ui:build": "cd frontend && npm run build",
    "build": "npm run server:build && npm run ui:build",
    "db:generate": "typeorm-ts-node-esm migration:generate -d ./backend/src/infra/db/database.ts",
    "db:migrate": "typeorm-ts-node-esm migration:run -d ./backend/src/infra/db/database.ts",
    "db:seed": "tsx --tsconfig ./backend/tsconfig.json ./backend/src/infra/db/seed-auth.ts",
    "provider": "bun ./scripts/auth.ts provider",
    "models": "bun ./scripts/auth.ts models"
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.8",
    "@mdi/font": "^7.4.47",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "connect-history-api-fallback": "^2.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "node-cache": "^5.1.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/connect-history-api-fallback": "^1.5.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.19",
    "tsc-alias": "^1.8.16"
  }
}
